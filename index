        // ============================================================
        //  SMART MATCH FINDER
        // ============================================================
        function findMatchResult(team1, team2) {
            const team1Ar = translateToArabic(team1);
            const team2Ar = translateToArabic(team2);
            let match = state.previousGamesData.find(m =>
                (m.homeAr === team1Ar && m.awayAr === team2Ar) ||
                (m.homeAr === team2Ar && m.awayAr === team1Ar)
            );
            if (match) {
                return {
                    homeScore: match.homeScore,
                    awayScore: match.awayScore,
                    homeAr: match.homeAr,
                    awayAr: match.awayAr,
                    homePenalty: match.homePenalty || null,
                    awayPenalty: match.awayPenalty || null,
                    hadPenalties: match.hadPenalties || false
                };
            }
            const team1Variants = getArabicToPersian(team1Ar);
            const team2Variants = getArabicToPersian(team2Ar);
            for (let t1 of team1Variants) {
                for (let t2 of team2Variants) {
                    const t1Ar = translateToArabic(t1);
                    const t2Ar = translateToArabic(t2);
                    const rawMatch = state.previousGamesData.find(m =>
                        (m.homeAr === t1Ar && m.awayAr === t2Ar) ||
                        (m.homeAr === t2Ar && m.awayAr === t1Ar)
                    );
                    if (rawMatch) {
                        return {
                            homeScore: rawMatch.homeScore,
                            awayScore: rawMatch.awayScore,
                            homeAr: rawMatch.homeAr,
                            awayAr: rawMatch.awayAr,
                            homePenalty: rawMatch.homePenalty || null,
                            awayPenalty: rawMatch.awayPenalty || null,
                            hadPenalties: rawMatch.hadPenalties || false
                        };
                    }
                }
            }
            if (team1Ar.includes("الكونغو") || team2Ar.includes("الكونغو") ||
                team1Ar.includes("جمهورية الكونغو") || team2Ar.includes("جمهورية الكونغو")) {
                const congoMatch = state.previousGamesData.find(m =>
                    m.homeAr.includes("الكونغو") || m.awayAr.includes("الكونغو") ||
                    m.homeAr.includes("جمهورية الكونغو") || m.awayAr.includes("جمهورية الكونغو")
                );
                if (congoMatch) {
                    return {
                        homeScore: congoMatch.homeScore,
                        awayScore: congoMatch.awayScore,
                        homeAr: congoMatch.homeAr,
                        awayAr: congoMatch.awayAr,
                        homePenalty: congoMatch.homePenalty || null,
                        awayPenalty: congoMatch.awayPenalty || null,
                        hadPenalties: congoMatch.hadPenalties || false
                    };
                }
            }
            return null;
        }

        // ============================================================
        //  DETERMINE WINNER - النسخة المعدلة
        // ============================================================
        function determineWinner(result) {
            if (!result) return null;
            
            // ============================================================
            //  الخطوة 1: التحقق من ضربات الجزاء
            // ============================================================
            // إذا كانت المباراة حُسمت بضربات جزاء، نستخدمها لتحديد الفائز
            if (result.hadPenalties && result.homePenalty !== null && result.awayPenalty !== null) {
                if (parseInt(result.homePenalty) > parseInt(result.awayPenalty)) {
                    return result.homeAr;  // الفريق المضيف فاز بضربات الجزاء
                } else if (parseInt(result.awayPenalty) > parseInt(result.homePenalty)) {
                    return result.awayAr;  // الفريق الضيف فاز بضربات الجزاء
                }
                // في حالة نادرة: تعادل في ضربات الجزاء (يستمرون حتى يحسمونها)
                return null;
            }
            
            // ============================================================
            //  الخطوة 2: الحالة العادية (بدون ضربات جزاء)
            // ============================================================
            if (result.homeScore > result.awayScore) {
                return result.homeAr;
            } else if (result.awayScore > result.homeScore) {
                return result.awayAr;
            }
            
            // ============================================================
            //  الخطوة 3: تعادل بدون ضربات جزاء
            // ============================================================
            // في حالة التعادل بدون ضربات جزاء، لا يوجد فائز
            return null;
        }

        function getPredictionStatus(prediction) {
            if (!prediction || !prediction.match_id) {
                return { status: 'pending', text: '⏳ مباراة غير معروفة' };
            }
            const parts = prediction.match_id.split('_');
            if (parts.length < 3) {
                return { status: 'pending', text: '⏳ بيانات غير مكتملة' };
            }
            const result = findMatchResult(parts[1], parts[2]);
            if (!result) {
                return { status: 'pending', text: '⏳ لم تلعب بعد' };
            }
            const correctResult = determineWinner(result);
            let predictionTeam = prediction.prediction;
            if (predictionTeam !== 'DRAW') {
                predictionTeam = translateToArabic(predictionTeam);
            }
            if (!correctResult) {
                if (predictionTeam === 'DRAW') {
                    return { status: 'correct', text: '✅ صحيح (تعادل)' };
                } else {
                    return { status: 'wrong', text: '❌ خاطئ (تعادل)' };
                }
            }
            if (predictionTeam === correctResult) {
                return { status: 'correct', text: `✅ صحيح (${correctResult})` };
            } else {
                return { status: 'wrong', text: `❌ خاطئ (الفائز: ${correctResult})` };
            }
        }

        // ============================================================
        //  حساب بيانات اللاعبين
        // ============================================================
        function calculatePlayersData() {
            const predictions = state.predictions || [];
            const scores = {};
            let totalPredictions = 0;

            for (let p of predictions) {
                totalPredictions++;
                if (!scores[p.user_name]) {
                    scores[p.user_name] = { name: p.user_name, points: 0, correct: 0, wrong: 0, total: 0,
                    predictions: [] };
                }
                scores[p.user_name].total++;
                scores[p.user_name].predictions.push(p);
                const parts = (p.match_id || "").split("_");
                if (parts.length < 3) continue;
                const result = findMatchResult(parts[1], parts[2]);
                if (!result) continue;
                const winner = determineWinner(result);
                let isCorrect = false;
                let predictionTeam = p.prediction;
                if (predictionTeam !== 'DRAW') {
                    predictionTeam = translateToArabic(predictionTeam);
                }
                if (winner === null) {
                    isCorrect = predictionTeam === 'DRAW';
                } else {
                    isCorrect = predictionTeam === winner;
                }
                if (isCorrect) {
                    scores[p.user_name].points++;
                    scores[p.user_name].correct++;
                } else {
                    scores[p.user_name].wrong++;
                }
            }

            const board = Object.values(scores).sort((a, b) => b.points - a.points || (b.correct - a.correct));

            let totalPoints = 0,
                maxPoints = 0,
                totalAccuracy = 0,
                maxAccuracy = 0,
                totalCorrect = 0,
                totalWrong = 0;
            board.forEach(p => {
                totalPoints += p.points;
                if (p.points > maxPoints) maxPoints = p.points;
                totalCorrect += p.correct;
                totalWrong += p.wrong;
                const acc = p.total > 0 ? (p.correct / p.total) * 100 : 0;
                totalAccuracy += acc;
                if (acc > maxAccuracy) maxAccuracy = acc;
            });

            const avgPoints = board.length > 0 ? Math.round(totalPoints / board.length) : 0;
            const avgAccuracy = board.length > 0 ? Math.round(totalAccuracy / board.length) : 0;

            state.playersData = {
                board: board,
                totalPlayers: board.length,
                totalPredictions: totalPredictions,
                avgPoints: avgPoints,
                maxPoints: maxPoints,
                avgAccuracy: avgAccuracy,
                maxAccuracy: Math.round(maxAccuracy),
                totalCorrect: totalCorrect,
                totalWrong: totalWrong
            };

            return state.playersData;
        }

        // ============================================================
        //  اللقب الواحد لكل لاعب (مختلف عن غيره)
        // ============================================================
        function getPlayerTitle(player, index, totalPlayers) {
            // ألقاب متنوعة
            const titles = [
                { minPoints: 20, label: '👑 محنك' },
                { minPoints: 15, label: '🧠 استراتيجي' },
                { minPoints: 10, label: '⚡ مغامر' },
