        // ============================================================
        //  OPEN PLAYER PREDICTIONS
        // ============================================================
        async function openPlayerPredictions(userName) {
            if (!userName) { showToast('⚠️ اسم المستخدم غير معروف'); return; }
            const modal = document.getElementById('playerPredictionsModal');
            const listContainer = document.getElementById('playerPredictionsList');
            document.getElementById('playerModalTitle').textContent = `📋 توقعات ${userName}`;
            document.getElementById('playerModalSubtitle').textContent = `👤 عرض جميع توقعات اللاعب ${userName}`;
            listContainer.innerHTML = `<div class="empty-state"><span class="icon">⏳</span> جاري التحميل...</div>`;

            let predictions = [];
            if (supabaseClient) {
                try {
                    const { data, error } = await supabaseClient
                        .from("predictions")
                        .select("*")
                        .eq("user_name", userName)
                        .order("created_at", { ascending: false });
                    if (!error && data) predictions = data;
                } catch (e) { console.warn("⚠️ فشل جلب توقعات اللاعب:", e); }
            }
            if (!predictions.length) {
                listContainer.innerHTML =
                    `<div class="empty-state"><span class="icon">📭</span> لا توجد توقعات لهذا اللاعب</div>`;
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
                return;
            }

            let correct = 0,
                wrong = 0,
                points = 0;
            const predictionsWithStatus = predictions.map(p => {
                const status = getPredictionStatus(p);
                if (status.status === 'correct') { correct++;
                    points++; } else if (status.status === 'wrong') { wrong++; }
                return { ...p, status };
            });
            const total = predictions.length;
            const accuracy = total > 0 ? Math.round((correct / total) * 100) : 0;
            document.getElementById('playerPoints').textContent = points;
            document.getElementById('playerCorrect').textContent = correct;
            document.getElementById('playerWrong').textContent = wrong;
            document.getElementById('playerTotal').textContent = total;
            document.getElementById('playerAccuracy').textContent = accuracy + '%';

            const allScores = {};
            const allPredictions = state.predictions || [];
            for (let p of allPredictions) {
                if (!allScores[p.user_name]) allScores[p.user_name] = { points: 0 };
                const parts = (p.match_id || "").split("_");
                if (parts.length < 3) continue;
                const result = findMatchResult(parts[1], parts[2]);
                if (!result) continue;
                const winner = determineWinner(result);
                let isCorrect = false;
                let predictionTeam = p.prediction;
                if (predictionTeam !== 'DRAW') predictionTeam = translateToArabic(predictionTeam);
                if (winner === null) { isCorrect = predictionTeam === 'DRAW'; } else { isCorrect = predictionTeam ===
                        winner; }
                if (isCorrect) allScores[p.user_name].points++;
            }
            const sorted = Object.entries(allScores).sort((a, b) => b[1].points - a[1].points);
            const rank = sorted.findIndex(([name]) => name === userName) + 1;
            document.getElementById('playerRank').textContent = rank > 0 ? `#${rank}` : '-';

            let html = '';
            predictionsWithStatus.forEach((p, idx) => {
                const parts = p.match_id ? p.match_id.split('_') : [];
                const team1Raw = parts.length > 1 ? parts[1] : '?';
                const team2Raw = parts.length > 2 ? parts[2] : '?';
                const team1Ar = translateToArabic(team1Raw);
                const team2Ar = translateToArabic(team2Raw);
                let predText = '';
                let predictionTeam = p.prediction;
                if (predictionTeam === 'DRAW') {
                    predText = '🤝 تعادل';
                } else {
                    const predTeamAr = translateToArabic(predictionTeam);
                    if (predTeamAr === team1Ar) {
                        predText = `🏆 فوز ${getFlag(team1Ar)} ${team1Ar}`;
                    } else if (predTeamAr === team2Ar) {
                        predText = `🏆 فوز ${getFlag(team2Ar)} ${team2Ar}`;
                    } else {
                        predText = `🔮 ${predictionTeam}`;
                    }
                }
                const status = p.status;
                let statusClass = 'pending',
                    statusText = '⏳ قيد الانتظار';
                if (status.status === 'correct') { statusClass = 'correct';
                    statusText = '✅ صحيح'; } else if (status.status === 'wrong') { statusClass = 'wrong';
                    statusText = '❌ خاطئ'; }
                const timeStr = p.created_at ? formatDate(p.created_at) : 'تاريخ غير معروف';
                html += `
                <div class="player-prediction-item">
                    <div class="num">#${idx + 1}</div>
                    <div class="match-info">
                        <div class="teams"><span class="flag">${getFlag(team1Ar)}</span> ${team1Ar} 🆚 <span class="flag">${getFlag(team2Ar)}</span> ${team2Ar}</div>
                        <div class="pred">🔮 ${predText}</div>
                        <span class="status ${statusClass}">${statusText}</span>
                    </div>
                    <div class="time">🕒 ${timeStr}</div>
                </div>
                `;
            });
            listContainer.innerHTML = html;
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // ============================================================
        //  CLOSE MODAL
        // ============================================================
        function closePlayerModal() {
            document.getElementById('playerPredictionsModal').classList.remove('active');
            document.body.style.overflow = '';
        }
        document.getElementById('playerModalCloseBtn').addEventListener('click', closePlayerModal);
        document.getElementById('playerPredictionsModal').addEventListener('click', function(e) {
            if (e.target === this) closePlayerModal();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closePlayerModal();
        });

        // ============================================================
        //  TOAST
        // ============================================================
        function showToast(msg) {
            const t = document.getElementById('copyToast');
            t.textContent = msg;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 2500);
        }

        // ============================================================
        //  THEME
        // ============================================================
        function toggleTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const newTheme = current === 'light' ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', newTheme === 'light' ? 'light' : '');
            localStorage.setItem('theme', newTheme);
            document.getElementById('themeToggle').textContent = newTheme === 'light' ? '☀️' : '🌙';
            if (document.getElementById('tab-chart').classList.contains('active')) {
                setTimeout(() => updateChart(), 150);
            }
        }
        if (localStorage.getItem('theme') === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
            document.getElementById('themeToggle').textContent = '☀️';
        }

        // ============================================================
        //  CLEAR CACHE AND RELOAD
        // ============================================================
        function clearCacheAndReload() {
            clearCache();
            showToast('🗑️ تم مسح الكاش');
            setTimeout(() => location.reload(), 400);
        }

        function startAutoUpdate() {
            setInterval(() => {
                renderLeaderboard(currentLeaderboardPeriod);
                updateStatsTab();
                if (document.getElementById('tab-chart').classList.contains('active')) {
                    updateChart();
                }
            }, 30000);
        }

        // ============================================================
        //  INIT
        // ============================================================
        async function init() {
            console.log("🚀 بدء التحميل");
            await loadPreviousGames();
            await getAllPredictions();
            state.loaded = true;
            renderLeaderboard('all');
            updateStatsTab();
            updateChartDropdown();
            startAutoUpdate();
            console.log("✅ تم التحميل");

            document.getElementById('compareInput1').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') comparePlayers();
            });
            document.getElementById('compareInput2').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') comparePlayers();
            });

            document.querySelector('[data-tab="chart"]').addEventListener('click', function() {
                setTimeout(() => updateChart(), 200);
            });
        }

        window.openPlayerPredictions = openPlayerPredictions;
        window.setLeaderboardPeriod = setLeaderboardPeriod;
        window.toggleTheme = toggleTheme;
        window.showToast = showToast;
        window.renderLeaderboard = renderLeaderboard;
        window.clearCacheAndReload = clearCacheAndReload;
        window.clearCache = clearCache;
        window.switchTab = switchTab;
        window.comparePlayers = comparePlayers;
        window.updateChart = updateChart;
        window.updateChartDropdown = updateChartDropdown;

        init();
    </script>

</body>
</html>