        // ============================================================
        //  عداد تدريجي (للهيرو)
        // ============================================================
        function animateCounterStatic(elementId, targetValue, suffix = '') {
            const el = document.getElementById(elementId);
            if (!el) return;
            const duration = 1600;
            const start = performance.now();

            function update(currentTime) {
                const elapsed = currentTime - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = Math.round(0 + (targetValue - 0) * eased);
                el.textContent = current + suffix;
                if (progress < 1) {
                    requestAnimationFrame(update);
                } else {
                    el.textContent = targetValue + suffix;
                }
            }
            requestAnimationFrame(update);
        }

        // ============================================================
        //  SLIDE AUTO-PLAY – 6 ثوانٍ
        // ============================================================
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;
        let currentIndex = 0;
        let isTransitioning = false;
        let autoPlayInterval = null;
        const AUTO_PLAY_DELAY = 6000;

        const dotsContainer = document.getElementById('dotsContainer');
        for (let i = 0; i < totalSlides; i++) {
            const dot = document.createElement('span');
            dot.className = 'dot' + (i === 0 ? ' active' : '');
            dot.dataset.index = i;
            dotsContainer.appendChild(dot);
        }

        function updateDots() {
            document.querySelectorAll('.dot').forEach((dot, i) => {
                dot.classList.toggle('active', i === currentIndex);
            });
        }

        function goToSlide(index) {
            if (isTransitioning) return;
            if (index === currentIndex) return;
            if (index < 0 || index >= totalSlides) return;
            isTransitioning = true;
            const currentSlide = slides[currentIndex];
            const nextSlide = slides[index];
            const direction = index > currentIndex ? 'exit-left' : 'exit-right';
            currentSlide.classList.remove('active');
            currentSlide.classList.add(direction);
            setTimeout(() => {
                currentSlide.classList.remove(direction);
                nextSlide.classList.add('active');
                currentIndex = index;
                updateDots();
                setTimeout(() => { isTransitioning = false; }, 400);
            }, 700);
        }

        function nextSlide() {
            if (currentIndex < totalSlides - 1) {
                goToSlide(currentIndex + 1);
            } else {
                showEndCredits();
            }
        }

        function startAutoPlay() {
            if (autoPlayInterval) clearInterval(autoPlayInterval);
            autoPlayInterval = setInterval(nextSlide, AUTO_PLAY_DELAY);
        }

        // ============================================================
        //  END CREDITS
        // ============================================================
        let endCreditsShown = false;

        function showEndCredits() {
            if (endCreditsShown) return;
            endCreditsShown = true;
            clearInterval(autoPlayInterval);
            document.getElementById('navControls').style.opacity = '0';
            setTimeout(() => {
