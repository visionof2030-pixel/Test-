            }, 1500);
        }

        // ============================================================
        //  PARTICLES & STARS
        // ============================================================
        function createParticles() {
            const container = document.getElementById('particlesContainer');
            for (let i = 0; i < 60; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                p.style.left = Math.random() * 100 + '%';
                p.style.top = Math.random() * 100 + '%';
                p.style.animationDuration = (Math.random() * 20 + 15) + 's';
                p.style.animationDelay = (Math.random() * 20) + 's';
                p.style.width = (Math.random() * 3 + 2) + 'px';
                p.style.height = p.style.width;
                container.appendChild(p);
            }
        }
        createParticles();

        function createStars() {
            const container = document.getElementById('starfield');
            for (let i = 0; i < 100; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.animationDuration = (Math.random() * 4 + 3) + 's';
                star.style.animationDelay = (Math.random() * 6) + 's';
                star.style.width = (Math.random() * 2 + 1) + 'px';
                star.style.height = star.style.width;
                container.appendChild(star);
            }
        }
        createStars();

        // ============================================================
        //  WEB AUDIO (مشهد صوتي تشويقي)
        // ============================================================
        let audioCtx = null;
        let isMuted = false;
        let gainNode = null;

        function initAudio() {
            if (audioCtx) return;
            try {
                audioCtx = new(window.AudioContext || window.webkitAudioContext)();
                gainNode = audioCtx.createGain();
                gainNode.gain.value = 0.5;
                gainNode.connect(audioCtx.destination);
                playIntroSound();
            } catch (e) { console.warn("Web Audio not supported"); }
        }

        function playIntroSound() {
            if (!audioCtx || isMuted) return;
            try {
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.type = 'sine';
                osc.frequency.setValueAtTime(80, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(150, audioCtx.currentTime + 2);
                gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 3);
                osc.connect(gain);
                gain.connect(gainNode);
                osc.start(audioCtx.currentTime);
                osc.stop(audioCtx.currentTime + 3);

                const bufferSize = 2 * audioCtx.sampleRate;
                const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
                const data = buffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) {
                    data[i] = (Math.random() * 2 - 1) * Math.pow(Math.random(), 2);
                }
                const noise = audioCtx.createBufferSource();
                noise.buffer = buffer;
                const filter = audioCtx.createBiquadFilter();
                filter.type = 'lowpass';
                filter.frequency.value = 200;
                const noiseGain = audioCtx.createGain();
                noiseGain.gain.setValueAtTime(0.12, audioCtx.currentTime);
                noiseGain.gain.exponentialRampToValueAtTime(0.02, audioCtx.currentTime + 4);
                noise.connect(filter);
                filter.connect(noiseGain);
                noiseGain.connect(gainNode);
                noise.start(audioCtx.currentTime);
                noise.stop(audioCtx.currentTime + 4);

                setTimeout(() => {
                    if (isMuted || !audioCtx) return;
                    const osc2 = audioCtx.createOscillator();
                    const g2 = audioCtx.createGain();
                    osc2.type = 'sine';
                    osc2.frequency.setValueAtTime(1200, audioCtx.currentTime);
                    osc2.frequency.exponentialRampToValueAtTime(1800, audioCtx.currentTime + 0.8);
                    g2.gain.setValueAtTime(0.15, audioCtx.currentTime);
                    g2.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 1);
                    osc2.connect(g2);
                    g2.connect(gainNode);
                    osc2.start(audioCtx.currentTime);
                    osc2.stop(audioCtx.currentTime + 1);
                }, 600);
            } catch (e) {}
        }

        document.getElementById('muteBtn').addEventListener('click', function() {
            isMuted = !isMuted;
            this.innerHTML = isMuted ? '<i class="fas fa-volume-mute"></i>' : '<i class="fas fa-volume-up"></i>';
            if (gainNode) {
                gainNode.gain.value = isMuted ? 0 : 0.5;
            }
            if (!isMuted && !audioCtx) {
                initAudio();
            }
        });

        // ============================================================
        //  INIT
        // ============================================================
        function init() {
            // عرض لوحة المتصدرين
            renderLeaderboard();

            // تشغيل العدادات
            animateCounterStatic('heroPlayers', data.totalTeams);
            animateCounterStatic('heroPredictions', data.totalPredictions);
            animateCounterStatic('heroPoints', data.topPoints);

            // تفعيل الصوت عند أول تفاعل
            document.body.addEventListener('click', function firstTouch() {
                if (!audioCtx) {
                    initAudio();
                }
                document.body.removeEventListener('click', firstTouch);
            }, { once: true });

            // إخفاء الافتتاحية
            setTimeout(() => {
                document.getElementById('introLayer').classList.add('hide');
            }, 3500);

            // بدء العرض التلقائي
            setTimeout(() => {
                updateDots();
                startAutoPlay();
            }, 4000);

            // التحكم اليدوي بالنقاط
            document.querySelectorAll('.dot').forEach(dot => {
                dot.addEventListener('click', function() {
                    const idx = parseInt(this.dataset.index);
                    if (idx !== currentIndex) {
                        clearInterval(autoPlayInterval);
                        goToSlide(idx);
                        setTimeout(startAutoPlay, AUTO_PLAY_DELAY + 500);
                    }
                });
            });

            // إعادة تشغيل العرض عند النقر على شاشة النهاية
            document.getElementById('endCredits').addEventListener('click', function() {
                this.classList.remove('show');
                endCreditsShown = false;
                currentIndex = 0;
                slides.forEach((s, i) => {
                    s.classList.remove('active', 'exit-left', 'exit-right');
                    if (i === 0) s.classList.add('active');
                });
                updateDots();
                startAutoPlay();
                document.getElementById('navControls').style.opacity = '0.1';
            });
        }

        // تشغيل التطبيق
        init();
    </script>
</body>
</html>