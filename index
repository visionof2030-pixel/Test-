<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>كأس العالم 2026 — العرض الختامي</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        /* ============================================================
           RESET & ROOT – CINEMATIC
           ============================================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        :root {
            --gold: #d4a745;
            --gold-light: #f3d88a;
            --gold-glow: rgba(212, 167, 69, 0.3);
            --gold-gradient: linear-gradient(145deg, #f3d88a, #c99a2e);
            --bg-primary: #0b0e14;
            --bg-secondary: #111a27;
            --text-primary: #ecf3fa;
            --text-secondary: #8aa0c0;
            --text-muted: #4f6b8a;
            --success: #2ecc71;
            --danger: #e74c3c;
            --shadow-card: 0 20px 60px rgba(0, 0, 0, 0.8);
            --radius-lg: 24px;
            --radius-md: 14px;
            --transition: all 1.2s cubic-bezier(0.23, 1, 0.32, 1);
        }

        html,
        body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: 'Cairo', 'Segoe UI', sans-serif;
            background: #0b0e14;
            color: var(--text-primary);
            margin: 0;
            padding: 0;
        }

        /* ============================================================
           LAYER 0 – شاشة سوداء + كأس + افتتاحية
           ============================================================ */
        #introLayer {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #0b0e14;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 2.2s ease;
            opacity: 1;
            pointer-events: none;
            padding: 20px;
        }
        #introLayer.hide {
            opacity: 0;
            pointer-events: none;
        }

        #introLayer .intro-trophy {
            font-size: 4rem;
            color: var(--gold);
            text-shadow: 0 0 80px var(--gold-glow), 0 0 160px rgba(212, 167, 69, 0.15);
            animation: introTrophyPulse 3s ease-in-out infinite;
            margin-bottom: 16px;
        }
        @keyframes introTrophyPulse {
            0%,
            100% {
                transform: scale(1) rotate(-2deg);
                filter: drop-shadow(0 0 30px rgba(212, 167, 69, 0.2));
            }
            50% {
                transform: scale(1.05) rotate(2deg);
                filter: drop-shadow(0 0 60px rgba(212, 167, 69, 0.5));
            }
        }

        .intro-text {
            font-size: 1.4rem;
            font-weight: 300;
            color: var(--text-secondary);
            letter-spacing: 4px;
            text-align: center;
            line-height: 2;
            opacity: 0;
            animation: introTextReveal 2.4s ease forwards 0.8s;
            padding: 0 10px;
        }
        .intro-text strong {
            color: var(--gold-light);
            font-weight: 700;
        }
        @keyframes introTextReveal {
            0% {
                opacity: 0;
                transform: translateY(30px) scale(0.96);
            }
            100% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .intro-sub {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 10px;
            letter-spacing: 2px;
            opacity: 0;
            animation: introTextReveal 2s ease forwards 1.6s;
        }

        /* ============================================================
           LAYER 1 – المشاهد (السلايدات)
           ============================================================ */
        .slides-wrapper {
            position: relative;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
        }

        .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px 16px;
            opacity: 0;
            transform: scale(1.06) translateY(30px);
            transition: opacity 1.6s ease, transform 1.6s cubic-bezier(0.23, 1, 0.32, 1);
            pointer-events: none;
            will-change: transform, opacity;
            z-index: 1;
            overflow-y: auto;
            backface-visibility: hidden;
        }
        .slide.active {
            opacity: 1;
            transform: scale(1) translateY(0);
            pointer-events: auto;
            z-index: 10;
        }
        .slide.exit-left {
            opacity: 0;
            transform: scale(0.94) translateX(-40px) rotateY(4deg);
        }
        .slide.exit-right {
            opacity: 0;
            transform: scale(0.94) translateX(40px) rotateY(-4deg);
        }

        /* ============================================================
           LAYER 2 – الخلفية السينمائية
           ============================================================ */
        .slide-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            overflow: hidden;
            background: radial-gradient(ellipse at 30% 20%, rgba(212, 167, 69, 0.04) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(74, 158, 255, 0.02) 0%, transparent 50%),
                var(--bg-primary);
        }

        .particles-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            pointer-events: none;
        }
        .particle {
            position: absolute;
            width: 3px;
            height: 3px;
            background: var(--gold);
            border-radius: 50%;
            opacity: 0.15;
            box-shadow: 0 0 12px rgba(212, 167, 69, 0.05);
            animation: particleDrift linear infinite;
            will-change: transform;
        }
        @keyframes particleDrift {
            0% {
                transform: translateY(0) translateX(0) scale(1);
                opacity: 0.05;
            }
            50% {
                opacity: 0.3;
            }
            100% {
                transform: translateY(-110vh) translateX(30px) scale(0.5);
                opacity: 0;
            }
        }

        .fog-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 200%;
            height: 200%;
            background: radial-gradient(ellipse at 50% 30%, rgba(212, 167, 69, 0.01) 0%, transparent 60%);
            animation: fogMove 18s ease-in-out infinite alternate;
            pointer-events: none;
        }
        @keyframes fogMove {
            0% {
                transform: translateX(-10%) translateY(-5%) scale(1);
            }
            100% {
                transform: translateX(10%) translateY(5%) scale(1.05);
            }
        }

        .stadium-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background:
                radial-gradient(ellipse at 50% 90%, rgba(212, 167, 69, 0.02) 0%, transparent 40%),
                radial-gradient(ellipse at 20% 70%, rgba(255, 255, 255, 0.005) 0%, transparent 30%),
                radial-gradient(ellipse at 80% 70%, rgba(255, 255, 255, 0.005) 0%, transparent 30%);
            pointer-events: none;
            animation: stadiumPulse 12s ease-in-out infinite;
        }
        @keyframes stadiumPulse {
            0%,
            100% {
                opacity: 0.5;
            }
            50% {
                opacity: 0.9;
            }
        }

        .camera-flash {
            position: absolute;
            width: 2px;
            height: 2px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
            animation: flashRandom 6s infinite;
            pointer-events: none;
        }
        @keyframes flashRandom {
            0%,
            100% {
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            15% {
                opacity: 0;
            }
            40% {
                opacity: 0;
            }
            50% {
                opacity: 0.8;
            }
            55% {
                opacity: 0;
            }
            80% {
                opacity: 0;
            }
            90% {
                opacity: 0.5;
            }
            95% {
                opacity: 0;
            }
        }

        /* ============================================================
           LAYER 3 – محتوى الشريحة
           ============================================================ */
        .slide-content {
            position: relative;
            z-index: 2;
            max-width: 1000px;
            width: 100%;
            text-align: center;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(12px) saturate(1.2);
            -webkit-backdrop-filter: blur(12px) saturate(1.2);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: var(--radius-lg);
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3), inset 0 0 60px rgba(212, 167, 69, 0.01);
            transition: var(--transition);
        }

        .chapter-tag {
            display: inline-block;
            font-size: 0.55rem;
            font-weight: 700;
            letter-spacing: 3px;
            color: var(--gold-light);
            background: rgba(212, 167, 69, 0.08);
            border: 1px solid rgba(212, 167, 69, 0.12);
            padding: 3px 16px;
            border-radius: 60px;
            margin-bottom: 10px;
            text-transform: uppercase;
            backdrop-filter: blur(8px);
        }

        .slide-content h1 {
            font-size: 2.8rem;
            font-weight: 900;
            line-height: 1.15;
            margin-bottom: 12px;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 0 80px rgba(212, 167, 69, 0.06);
            letter-spacing: -0.3px;
        }
        .slide-content h1 .highlight {
            color: var(--text-primary);
            background: none;
            -webkit-background-clip: unset;
            background-clip: unset;
        }

        .slide-content .subtitle {
            font-size: 1.1rem;
            color: var(--text-secondary);
            font-weight: 400;
            max-width: 600px;
            margin: 0 auto 16px;
            padding: 0 10px;
        }
        .slide-content .subtitle strong {
            color: var(--gold-light);
            font-weight: 700;
        }
        .slide-content .desc {
            font-size: 0.95rem;
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto 20px;
            line-height: 1.8;
            padding: 0 10px;
        }
        .slide-content .desc .accent {
            color: var(--gold-light);
            font-weight: 600;
        }

        /* ============================================================
           عناصر خاصة (الكأس، Spotlight، منصة التتويج)
           ============================================================ */
        .trophy-wrapper {
            position: relative;
            display: inline-block;
            margin: 4px 0;
        }
        .trophy-3d {
            display: inline-block;
            font-size: 3.8rem;
            filter: drop-shadow(0 0 40px rgba(212, 167, 69, 0.15));
            animation: trophySpin 14s linear infinite, trophyGlow 3s ease-in-out infinite alternate;
            transform-origin: center;
            will-change: transform;
        }
        @keyframes trophySpin {
            0% {
                transform: rotateY(0deg) scale(1);
            }
            100% {
                transform: rotateY(360deg) scale(1);
            }
        }
        @keyframes trophyGlow {
            0% {
                filter: drop-shadow(0 0 20px rgba(212, 167, 69, 0.1)) brightness(1);
            }
            100% {
                filter: drop-shadow(0 0 60px rgba(212, 167, 69, 0.3)) brightness(1.15);
            }
        }
        .trophy-wrapper::after {
            content: '';
            position: absolute;
            top: -20%;
            left: -10%;
            width: 140%;
            height: 140%;
            background: radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.06) 0%, transparent 60%);
            pointer-events: none;
            animation: lensFlare 6s ease-in-out infinite alternate;
        }
        @keyframes lensFlare {
            0% {
                transform: translateX(-10%) translateY(-10%) scale(0.8);
                opacity: 0.2;
            }
            100% {
                transform: translateX(20%) translateY(20%) scale(1.4);
                opacity: 0.6;
            }
        }

        .spotlight {
            position: relative;
        }
        .spotlight::before {
            content: '';
            position: absolute;
            top: -20%;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;
            height: 140%;
            background: radial-gradient(ellipse at center, rgba(212, 167, 69, 0.06) 0%, transparent 70%);
            pointer-events: none;
            animation: spotlightPulse 3s ease-in-out infinite alternate;
        }
        @keyframes spotlightPulse {
            0% {
                opacity: 0.3;
                transform: translateX(-50%) scale(0.9);
            }
            100% {
                opacity: 0.8;
                transform: translateX(-50%) scale(1.1);
            }
        }

        /* ============================================================
           PODIUM – منصة التتويج (متجاوبة)
           ============================================================ */
        .podium-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: flex-end;
            gap: 10px;
            margin: 10px 0;
            perspective: 600px;
        }
        .podium-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
            background: rgba(212, 167, 69, 0.04);
            border: 1px solid rgba(212, 167, 69, 0.10);
            border-radius: var(--radius-md);
            padding: 8px 12px 6px;
            backdrop-filter: blur(12px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
            transition: transform 0.4s ease;
            transform: rotateX(2deg) rotateY(-1deg);
            min-width: 80px;
            flex: 1;
            max-width: 160px;
        }
        .podium-step:hover {
            transform: rotateX(0) rotateY(0) translateY(-4px);
        }
        .podium-step .rank-icon {
            font-size: 2rem;
            margin-bottom: 2px;
        }
        .podium-step .p-name {
            font-weight: 800;
            font-size: 0.75rem;
            color: var(--gold-light);
            text-align: center;
            line-height: 1.3;
        }
        .podium-step .p-stats {
            font-size: 0.5rem;
            color: var(--text-secondary);
            text-align: center;
        }
        .podium-1 {
            height: 120px;
            background: rgba(212, 167, 69, 0.08);
            border-color: var(--gold);
            box-shadow: 0 0 50px rgba(212, 167, 69, 0.06);
            max-width: 180px;
        }
        .podium-2 {
            height: 100px;
        }
        .podium-3 {
            height: 80px;
        }

        /* ============================================================
           COUNTER
           ============================================================ */
        .counter {
            font-size: 2.2rem;
            font-weight: 900;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: inline-block;
            font-variant-numeric: tabular-nums;
        }

        /* ============================================================
           STATS ROW
           ============================================================ */
        .stats-row {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
            margin: 12px 0 8px;
        }
        .stats-row .stat-item {
            text-align: center;
            min-width: 60px;
        }
        .stats-row .stat-item .number {
            font-size: 2rem;
            font-weight: 900;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: block;
        }
        .stats-row .stat-item .label {
            font-size: 0.6rem;
            color: var(--text-secondary);
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        /* ============================================================
           شاشة النهاية (النجوم)
           ============================================================ */
        #endCredits {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #080b10;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 3s ease;
            padding: 20px;
        }
        #endCredits.show {
            opacity: 1;
            pointer-events: auto;
        }
        #endCredits .starfield {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        #endCredits .star {
            position: absolute;
            width: 2px;
            height: 2px;
            background: white;
            border-radius: 50%;
            opacity: 0.2;
            animation: starTwinkle 4s ease-in-out infinite alternate;
        }
        @keyframes starTwinkle {
            0% {
                opacity: 0.05;
                transform: scale(0.8);
            }
            100% {
                opacity: 0.5;
                transform: scale(1.2);
            }
        }
        #endCredits .end-text {
            position: relative;
            z-index: 2;
            font-size: 1.6rem;
            font-weight: 300;
            color: var(--text-secondary);
            letter-spacing: 4px;
            text-align: center;
            line-height: 2;
            opacity: 0;
            animation: endTextAppear 3s ease forwards 1s;
        }
        #endCredits .end-text strong {
            color: var(--gold-light);
            font-weight: 700;
        }
        @keyframes endTextAppear {
            0% {
                opacity: 0;
                transform: translateY(30px) scale(0.96);
            }
            100% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* ============================================================
           NAV & MUTE BUTTON
           ============================================================ */
        .nav-controls {
            position: fixed;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 100;
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(10, 14, 23, 0.1);
            backdrop-filter: blur(16px);
            padding: 3px 12px;
            border-radius: 60px;
            border: 1px solid rgba(255, 255, 255, 0.02);
            opacity: 0.15;
            transition: opacity 0.4s ease;
        }
        .nav-controls:hover {
            opacity: 0.5;
        }
        .nav-controls .dots {
            display: flex;
            gap: 5px;
            align-items: center;
        }
        .nav-controls .dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            transition: all 0.4s ease;
            cursor: pointer;
        }
        .nav-controls .dot.active {
            background: var(--gold);
            width: 18px;
            border-radius: 10px;
            box-shadow: 0 0 16px rgba(212, 167, 69, 0.15);
        }

        #muteBtn {
            position: fixed;
            top: 16px;
            left: 16px;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: var(--text-secondary);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            font-size: 1rem;
            cursor: pointer;
            backdrop-filter: blur(8px);
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: inherit;
        }
        #muteBtn:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: var(--gold);
            color: var(--gold-light);
        }

        /* ============================================================
           RESPONSIVE – تحسينات الجوال
           ============================================================ */
        @media (max-width: 768px) {
            .slide {
                padding: 14px 10px;
                align-items: center;
                padding-top: 20px;
            }
            .slide-content h1 {
                font-size: 2rem;
                margin-bottom: 6px;
            }
            .slide-content .subtitle {
                font-size: 0.95rem;
            }
            .slide-content .desc {
                font-size: 0.8rem;
                margin-bottom: 12px;
            }
            .chapter-tag {
                font-size: 0.5rem;
                padding: 2px 12px;
                margin-bottom: 6px;
            }
            .trophy-3d {
                font-size: 3rem;
            }
            .stats-row {
                gap: 10px;
            }
            .stats-row .stat-item .number {
                font-size: 1.6rem;
            }
            .stats-row .stat-item .label {
                font-size: 0.5rem;
            }
            .counter {
                font-size: 1.6rem;
            }

            .podium-container {
                gap: 6px;
            }
            .podium-step {
                min-width: 60px;
                padding: 4px 6px;
                max-width: 120px;
            }
            .podium-step .rank-icon {
                font-size: 1.4rem;
            }
            .podium-step .p-name {
                font-size: 0.6rem;
            }
            .podium-step .p-stats {
                font-size: 0.45rem;
            }
            .podium-1 {
                height: 90px;
                max-width: 130px;
            }
            .podium-2 {
                height: 75px;
            }
            .podium-3 {
                height: 60px;
            }

            .other-players-grid {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 4px;
            }

            .intro-text {
                font-size: 1.1rem;
            }
            #endCredits .end-text {
                font-size: 1.2rem;
            }
            .glass-card {
                padding: 10px !important;
            }
            #muteBtn {
                width: 30px;
                height: 30px;
                font-size: 0.8rem;
                top: 10px;
                left: 10px;
            }
        }

        @media (max-width: 480px) {
            .slide-content h1 {
                font-size: 1.6rem;
            }
            .slide-content .subtitle {
                font-size: 0.8rem;
            }
            .slide-content .desc {
                font-size: 0.7rem;
            }
            .trophy-3d {
                font-size: 2.4rem;
            }
            .podium-step {
                min-width: 50px;
                max-width: 100px;
            }
            .podium-1 {
                height: 75px;
                max-width: 110px;
            }
            .podium-2 {
                height: 60px;
            }
            .podium-3 {
                height: 50px;
            }
            .podium-step .rank-icon {
                font-size: 1.2rem;
            }
            .podium-step .p-name {
                font-size: 0.5rem;
            }
            .podium-step .p-stats {
                font-size: 0.4rem;
            }
            .counter {
                font-size: 1.2rem;
            }
            .stats-row .stat-item .number {
                font-size: 1.2rem;
            }
            .intro-text {
                font-size: 0.9rem;
            }
            #endCredits .end-text {
                font-size: 1rem;
            }
            .nav-controls {
                bottom: 10px;
                padding: 2px 8px;
                gap: 6px;
            }
            .nav-controls .dot {
                width: 4px;
                height: 4px;
            }
            .nav-controls .dot.active {
                width: 14px;
            }
            .chapter-tag {
                font-size: 0.4rem;
                padding: 2px 10px;
            }
            .other-players-grid {
                grid-template-columns: 1fr 1fr !important;
            }
        }

        /* ============================================================
           UTILITIES
           ============================================================ */
        .text-gold {
            color: var(--gold-light);
        }
        .text-muted {
